+         ok &= check_true(png_get_pixels_per_inch(png_ptr, info_ptr) ==
+            expected_ppi(ppm), "png_get_pixels_per_inch edge");
+      }
+
+      png_set_pHYs(png_ptr, info_ptr, 3000, 1000, PNG_RESOLUTION_METER);
