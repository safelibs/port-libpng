-               bpp = bit_depth;
-               break;
-
-            case PNG_COLOR_TYPE_GA:
-               sig_bits[0] = sBIT->gray;
-               sig_bits[1] = sBIT->alpha;
-               bpp = 2 * bit_depth;
-               break;
-
-            case PNG_COLOR_TYPE_RGB:
-               sig_bits[0] = sBIT->red;
-               sig_bits[1] = sBIT->green;
-               sig_bits[2] = sBIT->blue;
-               bpp = 3 * bit_depth;
-               break;
-
-            case PNG_COLOR_TYPE_RGBA:
-               sig_bits[0] = sBIT->red;
-               sig_bits[1] = sBIT->green;
-               sig_bits[2] = sBIT->blue;
-               sig_bits[3] = sBIT->alpha;
