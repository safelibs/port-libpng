+    read_info_loop(png_ptr, info_ptr);
+    if !info_ptr.is_null() {
+        let source_info = state::get_info(info_ptr);
+        state::update_png(png_ptr, |png_state| {
+            png_state.read_info_ptr = info_ptr;
+            png_state.read_source_info = source_info;
+        });
+    }
