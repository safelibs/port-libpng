+#endif
+
+      png_set_pHYs(png_ptr, info_ptr, 1, PNG_UINT_31_MAX, PNG_RESOLUTION_METER);
+#ifdef PNG_FIXED_POINT_SUPPORTED
+      ok &= check_true(png_get_pixel_aspect_ratio_fixed(png_ptr, info_ptr) == 0,
