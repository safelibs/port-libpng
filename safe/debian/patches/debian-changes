+                png_state.progressive_state.current_input_start =
+                    png_state.progressive_state.buffered.len();
+                png_state.progressive_state.current_input_size = input.len();
+                png_state
+                    .progressive_state
+                    .buffered
+                    .extend_from_slice(input);
+            });
+        } else {
