-               b |= b << 2;
-               b |= b << 4;
-               sig_bits[0] = (png_byte)b;
-               break;
-
-            case 4: /* Replicate twice */
-               /* Value is 1, 2, 3 or 4 */
-               b = 0xf & ((0xf << 4) >> sig_bits[0]);
-               b |= b << 4;
