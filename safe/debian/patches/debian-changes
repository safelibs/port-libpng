+fn palette_color(info_state: Option<&state::PngInfoState>, index: usize) -> Option<[u16; 3]> {
+    let info_state = info_state?;
+    let color = info_state.palette.get(index)?;
+    Some([
+        u16::from(color.red),
+        u16::from(color.green),
+        u16::from(color.blue),
+    ])
+}
