-static int
-do_test(struct display *dp, const char *file)
-   /* Exists solely to isolate the setjmp clobbers */
-{
-   dp->error_code = VERBOSE; /* The "lowest" level */
-
-   if (setjmp(dp->error_return) == 0)
-   {
-      test_one_file(dp, file);
-      return 0;
-   }
