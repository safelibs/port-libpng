+fn finish_gray_alpha_colormapped_read(
+    image: &mut png_image,
+    decoded: &DecodedImage,
+    background: png_const_colorp,
+    buffer: png_voidp,
+    row_stride: png_int_32,
+    colormap: png_voidp,
+    entry_format: png_uint_32,
+    entry_size: usize,
+    max_entries: usize,
