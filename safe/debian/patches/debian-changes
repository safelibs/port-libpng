+fn div51(value: u8) -> u8 {
+    (((u16::from(value) * 5) + 130) >> 8) as u8
+}
+
+fn rgb_cube_index(r: u8, g: u8, b: u8) -> u8 {
+    6 * (6 * div51(r) + div51(g)) + div51(b)
+}
+
+fn rgb_mid_index(value: u8) -> u8 {
+    if value < 64 {
+        0
+    } else if value < 192 {
+        1
+    } else {
+        2
+    }
+}
