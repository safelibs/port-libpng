-         pow(sRGB_to_d[value], 1/2.2) - sRGB_from_linear(pow(vd, 2.2)));
-
-      /* Always allow an extra 1 here for rounding errors */
-      e = 1+floor(255 * e);
-      return (int)e;
-   }
