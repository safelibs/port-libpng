+    unsigned char *data = (unsigned char *)malloc((size_t)size);
+    assert(data != NULL);
+    assert(fread(data, 1, (size_t)size, fp) == (size_t)size);
+    fclose(fp);
+    *size_out = (size_t)size;
+    return data;
