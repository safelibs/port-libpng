+            image_ref,
+            state.source_format,
+            &decoded,
+            background,
+            buffer,
+            row_stride,
+            colormap,
+        )
+    } else {
+        finish_direct_read(
+            image_ref,
+            state.source_format,
+            &decoded,
+            background,
+            buffer,
+            row_stride,
