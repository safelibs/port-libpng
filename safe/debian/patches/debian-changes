+static unsigned char *read_entire_file(const char *path, size_t *size_out) {
+    FILE *fp = fopen(path, "rb");
+    assert(fp != NULL);
+    assert(fseek(fp, 0, SEEK_END) == 0);
+    long size = ftell(fp);
+    assert(size >= 0);
