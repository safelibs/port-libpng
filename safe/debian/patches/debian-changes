+        &decodable_bytes,
+        &core,
+        options,
+        info_state.as_ref(),
+        filler,
+    ) else {
+        return None;
+    };
+    state::update_png(png_ptr, |png_state| {
+        png_state.decoded_read_image = Some(image.clone());
+        png_state.core = updated_core;
+    });
