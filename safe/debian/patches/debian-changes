-#ifdef PNG_WRITE_PNG_SUPPORTED
-static void
-buffer_start_write(struct buffer *buffer)
-{
-   buffer->last = &buffer->first;
-   buffer->end_count = 0;
-   buffer->current = NULL;
-}
-#endif
-
-static void
-buffer_start_read(struct buffer *buffer)
-{
-   buffer->current = &buffer->first;
-   buffer->read_count = 0;
-}
