+unsafe fn rollback_and_rethrow(
+    png_ptr: png_structrp,
+    info_ptr: png_inforp,
+    snapshot: &ParseSnapshot,
+) -> ! {
+    unsafe { rollback_parse_state(png_ptr, info_ptr, snapshot) };
+    unsafe { free_parse_snapshot(snapshot) };
