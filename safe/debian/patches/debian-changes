+    if let Some(trailer_info_state) = trailer_info_state {
+        write_post_idat_chunks(
+            &mut writer,
+            trailer_info_state,
+            trailer_text_index,
+            write_trailer_time,
+            write_trailer_exif,
+        )
+        .map_err(|_| b"write error\0".as_slice())?;
+    }
+    drop(writer);
