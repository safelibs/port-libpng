+    let state = unsafe { &*image_ref.opaque.cast::<SimplifiedImageState>() };
+    let decoded = match decode_png(&state.bytes, image_ref.flags) {
+        Ok(decoded) => decoded,
+        Err(err) => return set_image_error(image, format!("png_image_finish_read failed: {err}")),
+    };
