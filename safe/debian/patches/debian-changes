+                png_state.core,
+                png_state.options,
+                png_state.read_info_ptr,
+                png_state.read_source_info.clone(),
+                ((png_state.core.transformations & (PNG_FILLER | PNG_ADD_ALPHA)) != 0).then_some(
+                    FillerTransform {
+                        value: png_state.filler,
+                        after: (png_state.core.flags & PNG_FLAG_FILLER_AFTER) != 0,
+                    },
+                ),
+            )
+        })?;
+    if bytes.is_empty() {
+        return None;
