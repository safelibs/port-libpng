+pub(crate) unsafe fn read_info_impl(png_ptr: png_structrp, info_ptr: png_inforp) {
+    if state::get_png(png_ptr)
+        .map(|png_state| usize::try_from(png_state.sig_bytes).unwrap_or(0) < PNG_SIGNATURE.len())
+        .unwrap_or(true)
