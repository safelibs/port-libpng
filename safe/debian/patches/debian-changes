+fn write_memory_output(
+    bytes: &[u8],
+    memory: png_voidp,
+    memory_bytes: *mut png_alloc_size_t,
+) -> c_int {
+    if memory_bytes.is_null() {
+        return 0;
+    }
+
+    unsafe {
+        if memory.is_null() {
+            *memory_bytes = bytes.len();
+            return 1;
+        }
+
+        if *memory_bytes < bytes.len() {
+            *memory_bytes = bytes.len();
+            return 0;
+        }
+
+        ptr::copy_nonoverlapping(bytes.as_ptr(), memory.cast::<u8>(), bytes.len());
+        *memory_bytes = bytes.len();
+    }
+
+    1
+}
