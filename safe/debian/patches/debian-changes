+def main() -> int:
+    if len(sys.argv) < 2:
+        print(
+            "usage: normalize-package-metadata.py <buildinfo|changes> <tool-args...>\n"
+            "   or: normalize-package-metadata.py watch <binary|source>",
+            file=sys.stderr,
