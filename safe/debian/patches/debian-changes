+pub(crate) unsafe fn write_to_file(
+    image: png_imagep,
+    file_name: png_const_charp,
+    convert_to_8bit: c_int,
+    buffer: png_const_voidp,
+    row_stride: png_int_32,
+    colormap: png_const_voidp,
