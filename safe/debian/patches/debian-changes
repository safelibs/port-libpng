+fn sample_to_u8(sample: u16, sample_bytes: usize) -> u8 {
+    if sample_bytes == 1 {
+        sample as u8
+    } else {
+        ((((u32::from(sample) * 255) + 32_895) >> 16) & 0xff) as u8
+    }
