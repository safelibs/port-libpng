+            location = (mode & (PNG_HAVE_IHDR | PNG_HAVE_PLTE | PNG_AFTER_IDAT)) as c_int;
+        }
+        if location == 0 {
+            location = PNG_HAVE_IHDR as c_int;
+        }
+    }
+
+    while location != (location & -location) {
+        location &= !(location & -location);
+    }
+
+    location as png_byte
+}
