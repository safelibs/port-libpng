+    }
+
+    let channels = if info_core.channels != 0 {
+        usize::from(info_core.channels)
+    } else {
+        usize::from(png_core.channels)
+    };
+    let bit_depth = if info_core.bit_depth != 0 {
+        usize::from(info_core.bit_depth)
+    } else {
+        usize::from(png_core.bit_depth)
