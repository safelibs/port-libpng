+            push_linear16(&mut out, pixel.r);
+            push_linear16(&mut out, pixel.g);
+            push_linear16(&mut out, pixel.b);
+        }
+        (PngColorType::Rgba, PngBitDepth::Sixteen) => {
+            push_linear16(&mut out, pixel.r);
+            push_linear16(&mut out, pixel.g);
