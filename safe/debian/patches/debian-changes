+fn ppi_from_ppm(ppm: png_uint_32) -> png_uint_32 {
+    if ppm > PNG_UINT_31_MAX {
+        return 0;
+    }
+
+    (((ppm as u64) * 127 + 2_500) / 5_000) as png_uint_32
